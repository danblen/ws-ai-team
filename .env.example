# ---- Remote 访问配置（可选） ----
# 设置后所有 /api/* 请求需携带 Authorization: Bearer <token>
# 部署到公网时务必设置
# API_TOKEN=my-secret-token

# ---- 登录鉴权（邮箱+密码） ----
# 会话令牌的签名密钥。不填则自动生成并存于 server/.data/secret
# 部署到公网建议显式设置一个高强度随机串
# AUTH_SECRET=change-me-to-a-long-random-string

# 是否强制登录。默认：一旦有用户注册（server/.data/users.json）或设置了 API_TOKEN 即强制。
# 想在没有任何用户时也强制登录，设为 1
# AUTH_REQUIRED=1

# CORS 允许的来源，逗号分隔（可选，默认允许所有来源）
# 生产环境建议设为你的前端域名
# ALLOWED_ORIGINS=https://aiteam.example.com

# 后端服务端口（可选，默认 5110）
# SERVER_PORT=5110
